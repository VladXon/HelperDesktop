NODE_ENV=production
PORT=3001
LOG_LEVEL=info
DATABASE_URL=postgresql://user:password@your-db-host:5432/helperdesktop
BOT_PATH=../bot
BOT_USERNAME=YourBotUsername
JWT_SECRET=change-me-min-32-chars-recommended
BOT_SHARED_SECRET=change-me-shared-with-bot
CORS_ORIGINS=https://yourdomain.com
POE_CLIENT_ID=your-ggg-oauth-client-id
POE_CLIENT_SECRET=your-ggg-oauth-client-secret
POE_REDIRECT_URI=https://yourdomain.com/api/poe/auth/callback
POE_TOKEN_ENCRYPTION_KEY=your-64-char-hex-encryption-key
