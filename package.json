{
  "name": "helperdesktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "shamefully-hoist": true,
    "publicHoistPattern": [
      "*react*",
      "*radix*",
      "*markdown*",
      "*remark*",
      "*rehype*",
      "*unified*",
      "*vfile*",
      "*hast*",
      "*mdast*",
      "*micromark*",
      "*devlop*",
      "*floating-ui*",
      "*scheduler*",
      "*aria-hidden*",
      "*remove-scroll*",
      "*dijkstrajs*",
      "*html-url*",
      "*unist*",
      "*cmdk*",
      "*framer*",
      "*phosphor*"
    ]
  },
  "scripts": {
    "dev": "pnpm dev:client",
    "dev:all": "concurrently -n server,bot,client -c blue,green,magenta \"pnpm dev:server\" \"pnpm dev:bot\" \"pnpm dev:client\"",
    "dev:server": "pnpm --filter @helper/server dev",
    "dev:bot": "pnpm --filter @helper/bot dev",
    "dev:client": "pnpm --filter @helper/client dev",
    "build": "pnpm -r --filter=./packages/* build && pnpm -r --filter=./apps/* build",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm -r test:e2e",
    "deploy": "bash scripts/deploy.sh",
    "backup": "bash scripts/backup.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@fast-check/vitest": "^0.4.1",
    "concurrently": "^9.0.0",
    "typescript": "^5.8.0"
  }
}
