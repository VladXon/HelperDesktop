{
  "name": "helperdesktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20.0.0", "pnpm": ">=9.0.0" },
  "scripts": {
    "dev": "concurrently -n server,bot,client -c blue,green,magenta \"pnpm dev:server\" \"pnpm dev:bot\" \"pnpm dev:client\"",
    "dev:server": "pnpm --filter @helper/server dev",
    "dev:bot": "pnpm --filter @helper/bot dev",
    "dev:client": "pnpm --filter @helper/client dev",
    "build": "pnpm -r --filter=./packages/* build && pnpm -r --filter=./apps/* build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm -r test:e2e"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.8.0"
  }
}
