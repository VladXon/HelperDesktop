{
  "extends": "../../config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/__tests__/**", "src/legacy/__tests__/**", "src/legacy/**/__tests__/**"],
  "references": [
    { "path": "../shared" },
    { "path": "../poe-engine" }
  ]
}
